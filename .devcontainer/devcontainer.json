{
  // {sample-devcontainer} という文字列をプロジェクト名に置き換えてください(.claude/settings.local.jsonにも同様の置換が必要です)
  // サブパスがある場合は調整してね
  "name": "{sample-devcontainer}",
  "image": "mcr.microsoft.com/devcontainers/base:bookworm",
  "workspaceFolder": "/workspaces/{sample-devcontainer}",
  "features": {
    "ghcr.io/devcontainers/features/node:1": {},
    "ghcr.io/devcontainers/features/github-cli:1": {}
  },
  "mounts": [
    "source=claude-code-userdata-{sample-devcontainer},target=/home/vscode/.claude,type=volume"
  ],
  "postCreateCommand": "/workspaces/{sample-devcontainer}/.devcontainer/post_create.sh",
  "customizations": {
    "vscode": {
      "extensions": [
        "GitHub.copilot",
        "GitHub.copilot-chat"
      ]
    }
  }
}
